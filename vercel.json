{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": "{*.html,*.css,*.js,docs/**,fonts/**,images/**,server/**}"
    }
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
